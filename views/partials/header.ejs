        splashTextElement.style.zIndex = '100';
        splashTextElement.style.left = '30%';
        splashTextElement.style.transform = 'translateX(-30%)';
        splashTextElement.style.borderLeft = '5px solid #00FF00';
        splashTextElement.style.paddingLeft = '50px';
        splashTextElement.style.overflow = 'visible';
