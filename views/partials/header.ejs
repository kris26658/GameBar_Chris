    let splashTextElement = document.getElementById('partials-header-splash-text');
    let randomIndex = Math.floor(Math.random() * splashList.length);
    splashTextElement.innerHTML = splashList[randomIndex];

    if (splashTextElement.innerHTML == "#1 CSS<br><br> Dev   elop<br>er") {
        splashTextElement.style.fontSize = '1.2em';
        splashTextElement.style.color = '#123456';
        splashTextElement.style.textShadow = '0 0 10px #FF0000';
        splashTextElement.style.zIndex = '100';
        splashTextElement.style.left = '30%';
        splashTextElement.style.transform = 'translateX(-30%)';
        splashTextElement.style.borderLeft = '5px solid #00FF00';
        splashTextElement.style.paddingLeft = '50px';
        splashTextElement.style.overflow = 'visible';
