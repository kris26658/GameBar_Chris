    let user = JSON.parse('<%- JSON.stringify(user) %>');
    // GAME POINTS LOGIC
    // ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓
    function buyPoints(value, pogs) {
        const pinForm = document.getElementById("pinForm")
        const transactionPrompt = document.getElementById("transactionPrompt");
        const pinInput = document.getElementById("pinInput");

        //toggle pin form
        pinForm.style.display = 'block';
        transactionPrompt.innerText = value + " Game Points costs " + pogs + " digipogs. Please enter your PIN to confirm the transaction:";
        pinInput.value = '';
        pinInput.focus();
    }

    function confirmTransaction() {
        const pinForm = document.getElementById("pinForm")
        const pinInput = document.getElementById("pinInput");

        const pin = parseInt(pinInput.value);
        const value = transactionPrompt.innerText.split(" ")[0]; // extract the value from the prompt text
        const pogs = transactionPrompt.innerText.split(" ")[4]; // extract the pog cost from the prompt text
        let reward = parseInt(value);
        socket.emit('transaction', pin, pogs, reward, user);
    }

    function cancelTransaction() {
        const pinForm = document.getElementById("pinForm")

        pinForm.style.display = 'none';
        alert("Transaction cancelled.");
    }

    socket.on("transactionFailure", (responseMessage) => {
        alert(responseMessage);
    });

    socket.on('transactionSuccess', () => {
        alert("Transaction successful! Your Game Points balance has been updated. Visit/refresh the home page to view the change :)");
    });

    function gamePointsShop(state) {
        let shop = document.getElementById('gamePointsWindow');
        let mask = document.getElementById('mask');

        if (state === 'open') {
            shop.style.display = 'block';
            mask.style.display = 'block';
        } else {
            shop.style.display = 'none';
            mask.style.display = 'none';
        }
    }

    // BUTTON HOVER EFFECTS
    // ↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓↓
    let buttonsVar = document.getElementsByClassName('purchaseButtons');
    Array.prototype.forEach.call(buttonsVar, element => {
        element.addEventListener('mouseover', () => {
            element.style.transform = 'scale(0.95)';
            element.style.boxShadow = '0 0 15px #4d664d';
        });
        element.addEventListener('mouseout', () => {
            element.style.transform = 'scale(1)';
            element.style.boxShadow = 'none';
        });
    });


</script>

