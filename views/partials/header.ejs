<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            font-family: Arial, sans-serif;
            color: #4d664d;
            text-shadow: 2px 2px 3px rgb(13, 71, 71);
            font-weight: bold;
            background-color: #0f0f0f;
        }

        .partials-header {
            color: #4d664d;
        }

        #partials-header-hr {
            position: relative;
            width: 100%;
            border: 1px solid;
            box-shadow: 0px 0px 20px rgb(13, 71, 71);
            margin-top: 12px;
            margin-bottom: 20px;
            z-index: -2;
        }

        #partials-header-title {
            text-shadow: 0px 0px 20px rgb(13, 71, 71);
            font-size: 2em;
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            margin: 5px;
            z-index: 0;
        }

        #partials-header-user {
            margin: 7px;
            font-weight: 100;
            display: inline-flex;
        }

        #partials-header-logout-button {
            margin: 7px;
            padding: 5px 10px;
            background-color: rgb(23, 34, 34);
            border: solid 1px #4d664d;
            border-radius: 5px;
            cursor: pointer;
            display: inline-flex;
        }

        #partials-header-version {
            position: absolute;
            font-size: 0.9em;
            font-weight: 100;
        }

        #partials-header-logo {
            text-decoration: none;
            color: inherit;
        }

        #partials-header-gamepoints-button {
            height: 45px;
            width: 45px;
        }

        #partials-header-gamepoints-station {
            display: inline-flex;
            position: absolute;
            cursor: pointer;
            right: 20px;
            top: 10px;
        }

        #partials-header-gamepoints-label {
            margin-left: 4px;
            font-size: 1.1em;
            margin-top: 15px;
        }

        #gamePointsWindow {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background-color: #0f0f0f;
            border: solid 1px #4d664d;
            border-radius: 5px;
            padding: 20px;
            display: none;
            z-index: 10;
        }

        #mask {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            display: none;
            z-index: 5;
        }

        #closeWindow {
            display: block;
            margin: 0 auto;
            margin-top: 20px;
            padding: 5px 10px;
            background-color: rgb(23, 34, 34);
            border: solid 1px #4d664d;
            border-radius: 5px;
            cursor: pointer;
            color: #4d664d;
        }

        .purchaseButtons {
            width: 150px;
            height: 150px;
            margin-top: 10px;
            color: #4d664d;
            background-color: rgb(23, 34, 34);
            border: solid 1px #4d664d;
            border-radius: 5px;
            cursor: pointer;
            transition: transform 120ms ease, box-shadow 120ms ease;
        }

        #gamePointsDisplay {
            text-align: center;
            margin-top: 15px;
        }

        #partials-header-splash-text {
            font-size: 0.9em;
            color: #babf56;
            text-shadow: none;
            position: absolute;
            left: 50%;
            margin-left: 5px;
            transform: translateX(-50%);
            background-color: #0f0f0f;
            padding: 5px;
            z-index: -1;
            text-align: center;
        }

        ::-webkit-scrollbar {
            width: 4px;
        }

        ::-webkit-scrollbar-track {
            background: #0f0f0f;
            border-radius: 10px;
        }

        ::-webkit-scrollbar-thumb {
            background: #4d664d;
            border-radius: 5px;
        }
    </style>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();        
    </script>
</head>

<body>
    <div>
        <a href='/' id="partials-header-logo">
            <h1 class='partials-header' id="partials-header-title"><%- pageName %></h1>
            <div id="partials-header-version"><%- version %></div>
        </a>
        <p class='partials-header' id="partials-header-user">Logged in as <%- user %></p><button class="partials-header"
            id="partials-header-logout-button" onclick="location.href='/logout'">Logout</button>

        <div onclick="gamePointsShop('open')" id="partials-header-gamepoints-station">
            <img src="/index/bag.png" id="partials-header-gamepoints-button">
            <h3 id="partials-header-gamepoints-label">Game Points</h3>
        </div>


        <div id="partials-header-splash-text-container">
            <div id="partials-header-splash-text"></div>
        </div>


        <hr class='partials-header' id="partials-header-hr" />
    </div>
    <div id="mask"></div>
    <div id="gamePointsWindow">
        <h3 style="text-align: center;">Game Points Shop</h3>
        <div id="purchaseButtonDiv">
            <button class="purchaseButtons" onclick="buyPoints(100, 99)">100 Game Points<br>99
                Digipogs</button>
            <button class="purchaseButtons" onclick="buyPoints(210, 199)">210 Game Points<br>199
                Digipogs</button>
            <button class="purchaseButtons" onclick="buyPoints(385, 349)">385 Game Points<br>349
                Digipogs</button>
            <button class="purchaseButtons" onclick="buyPoints(840, 699)">840 Game Points<br>699
                Digipogs</button>
            <button class="purchaseButtons" onclick="buyPoints(1300, 999)">1300 Game Points<br>999
                Digipogs</button>
        </div>

        <p id="gamePointsDisplay">You have <%- gp %> game points</p>

        <button id="closeWindow" onclick="gamePointsShop('close')">Close</button>
    </div>

</body>
